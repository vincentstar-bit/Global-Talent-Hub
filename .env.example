# ─── Database (Replit PostgreSQL) ────────────────────────────────────────────
# Automatically provided by Replit when the PostgreSQL database is provisioned.
# DATABASE_URL is set automatically — do not override it manually.
# DATABASE_URL=postgresql://...

# ─── Admin Auth ──────────────────────────────────────────────────────────────
# Set these in Replit Secrets (not in code or .replit)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address — must be a verified domain in your Resend account
FROM_EMAIL=notifications@sinoglobal.com

# Admin email — where contact form submissions and HR notifications are sent
ADMIN_EMAIL=your-admin@example.com
