{
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/company-site run build",
  "outputDirectory": "artifacts/company-site/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-app.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
